{
  "name": "spotify-history-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node -e \"const fs=require('fs');fs.writeFileSync('docs/.nojekyll','');if(fs.existsSync('CNAME'))fs.copyFileSync('CNAME','docs/CNAME');\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config ../tests/playwright.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "plotly.js-dist-min": "^3.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-plotly.js": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/plotly.js-dist-min": "^2.3.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-plotly.js": "^2.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "es5-ext@0.10.64": true
  }
}
